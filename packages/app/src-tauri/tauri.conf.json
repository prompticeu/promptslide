{
  "productName": "PromptSlide",
  "version": "0.1.0",
  "identifier": "com.promptslide.app",
  "build": {
    "beforeDevCommand": "node src/launcher.mjs",
    "frontendDist": "../src",
    "devUrl": "http://localhost:29171"
  },
  "app": {
    "windows": [
      {
        "title": "PromptSlide",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
