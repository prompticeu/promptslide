{
  "name": "powervibe",
  "version": "0.1.0",
  "description": "Vibe-code beautiful slide decks with your favorite coding agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./src/css/globals.css",
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./vite": {
      "import": "./dist/vite/plugin.js",
      "types": "./dist/vite/plugin.d.ts"
    }
  },
  "bin": {
    "powervibe": "./bin/cli.mjs"
  },
  "files": [
    "dist/",
    "bin/",
    "src/css/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.3.5",
    "@vitejs/plugin-react": "^4.5.2",
    "postcss": "^8.5.6",
    "@tailwindcss/postcss": "^4.1.13",
    "tailwindcss": "^4.1.13"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "framer-motion": "^11.0.0 || ^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "framer-motion": "^12.23.22",
    "tsup": "^8.4.0",
    "typescript": "^5.9.2"
  },
  "keywords": [
    "slides",
    "presentation",
    "react",
    "vite",
    "tailwind",
    "framer-motion",
    "coding-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prompticeu/powervibe.git",
    "directory": "packages/powervibe"
  }
}
